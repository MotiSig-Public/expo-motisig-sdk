# Optional: copy to .env.release (gitignored) if you publish with an access token
# instead of npm login. scripts/release.sh also accepts npm login (~/.npmrc).
# Do not commit real values.

# npm access token for the @motisig scope (Automation or Granular Access Token).
# Create at https://www.npmjs.com/settings/~tokens
NPM_TOKEN=

# Optional: one-time password when your npm account requires 2FA on publish.
NPM_OTP=
